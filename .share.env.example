# Copy this file to .share.env only after deploying viewer-site.
# Never publish the real MLT_SHARE_RELAY_SECRET.
# Email OTP delivery values belong in the hosted viewer-site runtime, not this file.
MLT_SHARE_RELAY_URL=https://your-viewer-site.example
MLT_SHARE_RELAY_SECRET=replace_with_the_same_secret_used_by_the_relay
MLT_SHARE_RELAY_TIMEOUT_SECONDS=5
