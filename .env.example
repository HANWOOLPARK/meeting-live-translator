# Meeting Live Translator Phase 3
# Copy this file to .env to override defaults. Do not store secrets here.

# Localhost is the safe default. start_all.bat opens 127.0.0.1.
MLT_HOST=127.0.0.1
MLT_PORT=8765

# Allowed: tiny, base, small, medium
MLT_WHISPER_MODEL=small

# Speech recognition. Allowed: local, deepgram.
# Translation direction: ja_to_ko, ja_to_en, en_to_ko, en_to_ja, ko_to_ja, ko_to_en.
# Korean-source directions require Deepgram plus an applied Gemini or OpenAI Provider.
STT_PROVIDER=local
TRANSLATION_DIRECTION=ja_to_ko
DEEPGRAM_API_KEY=
DEEPGRAM_STT_MODEL=nova-3
# Kept only for legacy configuration compatibility. Runtime STT language and
# the active timing profile always follow TRANSLATION_DIRECTION.
DEEPGRAM_STT_LANGUAGE=ja
# These legacy/global values define the Japanese profile and are also the
# fallback for English/Korean when their language-specific value is omitted.
# Priority: language-specific value > legacy/global value > built-in default.
DEEPGRAM_STT_ENDPOINTING_MS=500
DEEPGRAM_STT_UTTERANCE_END_MS=1300
DEEPGRAM_STT_MAX_SEGMENT_SECONDS=8
DEEPGRAM_STT_EN_ENDPOINTING_MS=400
DEEPGRAM_STT_EN_UTTERANCE_END_MS=1000
DEEPGRAM_STT_EN_MAX_SEGMENT_SECONDS=6
DEEPGRAM_STT_KO_ENDPOINTING_MS=650
DEEPGRAM_STT_KO_UTTERANCE_END_MS=1500
DEEPGRAM_STT_KO_MAX_SEGMENT_SECONDS=8
# MAX_SEGMENT values are soft clause-boundary thresholds. Checkpoints update
# stable partial captions; only HARD_LIMIT is the forced final upper bound.
DEEPGRAM_STT_CHECKPOINT_SECONDS=4
# If omitted, HARD_LIMIT defaults to max(10, every resolved MAX_SEGMENT), up to 30.
# An explicitly smaller value is rejected as an invalid configuration.
DEEPGRAM_STT_HARD_LIMIT_SECONDS=10
DEEPGRAM_STT_OPEN_TIMEOUT_SECONDS=10
# A structurally incomplete speech_final/UtteranceEnd is held briefly for the
# next stable chunk. Complete sentences and short acknowledgements stay immediate.
DEEPGRAM_STT_JA_INCOMPLETE_FINAL_WAIT_SECONDS=0.9
DEEPGRAM_STT_EN_INCOMPLETE_FINAL_WAIT_SECONDS=0.7
DEEPGRAM_STT_KO_INCOMPLETE_FINAL_WAIT_SECONDS=1.5
# Legacy fallback for all three languages when a dedicated value is omitted:
# DEEPGRAM_STT_INCOMPLETE_FINAL_WAIT_SECONDS=0.9
DEEPGRAM_RECONNECT_MAX_ATTEMPTS=5
DEEPGRAM_RECONNECT_BASE_DELAY_SECONDS=0.5
DEEPGRAM_RECONNECT_MAX_DELAY_SECONDS=5
DEEPGRAM_RECONNECT_BUFFER_SECONDS=3

# Hybrid Deepgram + selective local Whisper verification. Only risky final
# candidates are rechecked. PCM stays in a 14-second memory ring and is never
# written to a session. A blank model reuses MLT_WHISPER_MODEL. local-files-only
# prevents an implicit model download; a missing cache falls back to Deepgram.
DEEPGRAM_RECHECK_ENABLED=true
DEEPGRAM_RECHECK_MODEL=
DEEPGRAM_RECHECK_BUFFER_SECONDS=14
DEEPGRAM_RECHECK_TIMEOUT_SECONDS=4
DEEPGRAM_RECHECK_QUEUE_MAX_SIZE=2
DEEPGRAM_RECHECK_LOCAL_FILES_ONLY=true

# Internal transcription format and bounded callback queue.
MLT_SAMPLE_RATE=16000
MLT_FRAME_QUEUE_SIZE=256

# The runtime still confirms CUDA by actual faster-whisper model initialization.
# On failure it falls back to CPU int8 without terminating the server.
MLT_PREFER_CUDA=true

# Translation is opt-in. Allowed: none, local, openai, gemini.
TRANSLATION_PROVIDER=none

# OpenAI Responses API. Keep the real key only in .env or the process environment.
OPENAI_API_KEY=
OPENAI_TRANSLATION_MODEL=gpt-5.4-mini

# Gemini API via the official google-genai SDK. Never commit a real key.
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_TRANSLATION_MODEL=your_gemini_model_here
GEMINI_TRANSLATION_TIMEOUT_SECONDS=20
GEMINI_TRANSLATION_MAX_RETRIES=2
GEMINI_TRANSLATION_CONTEXT_SEGMENTS=3

# NVIDIA Build hosted Riva Translate, used only by the explicit A/B comparison CLI.
# It is not registered as a selectable product translation Provider.
NVIDIA_API_KEY=
NVIDIA_TRANSLATION_MODEL=nvidia/riva-translate-4b-instruct-v1.1

# Paid/live test safety gates. Keep disabled during normal app and test runs.
RUN_OPENAI_LIVE_TEST=0
RUN_LOCAL_TRANSLATION_TEST=0
RUN_OPENAI_ANALYSIS_LIVE_TEST=0

# Phase 3 session storage. Audio storage remains unsupported and OFF.
SESSION_SAVE_ORIGINAL=true
SESSION_SAVE_TRANSLATION=true
SESSION_SAVE_ANALYSIS=true
SESSION_AUTO_RECOVER=true

# Post-meeting analysis is opt-in. Allowed: none, rule_based, openai, gemini.
# Gemini analysis reuses GEMINI_TRANSLATION_MODEL when its dedicated model is empty.
ANALYSIS_PROVIDER=none
OPENAI_ANALYSIS_MODEL=
GEMINI_ANALYSIS_MODEL=
ANALYSIS_TIMEOUT_SECONDS=60
ANALYSIS_MAX_RETRIES=1
ANALYSIS_AUTO_RUN_ON_STOP=false
ANALYSIS_MAX_SEGMENTS_PER_CHUNK=100
ANALYSIS_MAX_CHARS_PER_CHUNK=24000
ANALYSIS_MAX_CONCURRENCY=1

# Evidence-linked live Decision Radar. Only finalized transcripts are queued.
# The verified Build Week Replay uses GPT-5.6 Luna. The installed default stays
# cost-conscious and can be overridden here. Gemini falls back to
# GEMINI_ANALYSIS_MODEL and then GEMINI_TRANSLATION_MODEL when left empty.
DECISION_RADAR_PROVIDER=none
OPENAI_DECISION_RADAR_MODEL=gpt-5.4-mini
GEMINI_DECISION_RADAR_MODEL=
DECISION_RADAR_BATCH_SIZE=10
DECISION_RADAR_BATCH_WAIT_SECONDS=20
DECISION_RADAR_CONTEXT_SEGMENTS=16
DECISION_RADAR_QUEUE_MAX_SIZE=100
DECISION_RADAR_TIMEOUT_SECONDS=30
DECISION_RADAR_MAX_RETRIES=1

# Bounded asynchronous translation processing.
TRANSLATION_CONTEXT_SEGMENTS=3
TRANSLATION_QUEUE_MAX_SIZE=100
TRANSLATION_MAX_CONCURRENCY=2
TRANSLATION_TIMEOUT_SECONDS=20
TRANSLATION_MAX_RETRIES=2
TRANSLATION_TRANSLATE_UNKNOWN=false
TRANSLATION_GLOSSARY_FILE=

# Pre-installed isolated M2M100/CTranslate2 Worker. Normal startup never
# installs packages, downloads a model, or imports Transformers in main .venv.
LOCAL_TRANSLATION_RUNTIME_PYTHON=.venv-translation\Scripts\python.exe
LOCAL_TRANSLATION_MODEL=models\translation\m2m100_418m-int8

# Optional attendee invite-link relay. Keep the real shared secret only in the
# ignored .share.env file generated after viewer-site deployment.
MLT_SHARE_RELAY_URL=
MLT_SHARE_RELAY_SECRET=
MLT_SHARE_RELAY_TIMEOUT_SECONDS=5
